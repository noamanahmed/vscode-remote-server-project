{
  "name": "remotefs",
  "displayName": "RemoteFS",
  "description": "Remote Filesystem and Search Provider for VS Code",
  "version": "0.1.0",
  "publisher": "naumanahmed",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onFileSystem:remotefs",
    "onCommand:remotefs.testConnection",
    "onCommand:remotefs.openWorkspace"
  ],
  "main": "./dist/extension.js",
  "enabledApiProposals": [
    "textSearchProvider",
    "fileSearchProvider"
  ],
  "contributes": {
    "languages": [],
    "grammars": [],
    "commands": [
      {
        "command": "remotefs.openWorkspace",
        "title": "RemoteFS: Open Remote Workspace"
      },
      {
        "command": "remotefs.setupConnection",
        "title": "RemoteFS: Setup Connection"
      },
      {
        "command": "remotefs.testConnection",
        "title": "RemoteFS: Test Connection"
      }
    ],
    "configuration": {
      "title": "RemoteFS",
      "properties": {
        "remotefs.host": {
          "type": "string",
          "default": "localhost",
          "description": "Host name of the remote daemon"
        },
        "remotefs.port": {
          "type": "number",
          "default": 8765,
          "description": "Port of the remote daemon"
        }
      }
    },
    "menus": {},
    "submenus": []
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --minify",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.19.11",
    "typescript": "^5.3.3"
  }
}
